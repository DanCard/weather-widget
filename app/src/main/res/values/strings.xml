    <!-- Feature Tour Content -->
    <string name="tour_widget_sizing_title">Widget Sizing</string>
    <string name="tour_widget_sizing_desc">The widget adapts to different sizes:\n\n• 1x1: Forecast high for today (+ current temp if space allows)\n• 1x3: Yesterday, today, tomorrow (text only)\n• 2x3: Same as 1x3 but with graphical temperature bars\n• 4+ columns: Additional forecast days (4 cols = 2 forecast days, 5 cols = 3 forecast days, etc.)\n\nResize the widget by long-pressing it on your home screen and dragging the edges.</string>

    <string name="tour_current_temp_title">Current Temperature</string>
    <string name="tour_current_temp_desc">The large temperature in the top-left corner shows the current temperature, interpolated from hourly forecast data for smooth transitions. Updates 1–4 times per hour based on temperature change rate. Tap this to switch to the hourly temperature graph.</string>

    <string name="tour_api_toggle_title">Weather Data Source</string>
    <string name="tour_api_toggle_desc">Tap the API indicator in the top-right corner to toggle between weather sources:\n\n• NWS: National Weather Service (US only)\n• Meteo: Open-Meteo (global coverage)\n• WAPI: WeatherAPI (global coverage)\n\nYou can set your preferred source in Settings (Alternate, Prefer NWS, Prefer Open-Meteo, or Prefer WeatherAPI).</string>

    <string name="tour_navigation_title">Navigation</string>
    <string name="tour_navigation_desc">Use the left/right arrows to browse up to 30 days of historical weather data and future forecasts. Past days show actual temperatures compared to predictions for accuracy analysis.</string>

    <string name="tour_accuracy_title">Forecast Accuracy Tracking</string>
    <string name="tour_accuracy_desc">The app compares 1-day-ahead forecasts against actual weather. Five display modes available in Settings:\n\n• FORECAST_BAR (default): Yellow bar overlay showing predicted range alongside actual temperature bar\n• ACCURACY_DOT: Colored indicator (green ≤2°, yellow ≤5°, red >5° error)\n• SIDE_BY_SIDE: Shows "72° (N:68°)" with source abbreviation\n• DIFFERENCE: Shows "72° (N:+4)" with temperature difference\n• NONE: No forecast comparison\n\nView detailed 30-day statistics in the Statistics screen.</string>

    <string name="tour_settings_title">Settings &amp; Customization</string>
    <string name="tour_settings_desc">Access Settings to customize:\n\n• Accuracy Display Mode (how forecast comparisons are shown)\n• API Preference (which weather source to use)\n• View Detailed Statistics (30-day accuracy breakdown)\n• API Diagnostics (troubleshoot data fetching issues)\n\nOpen Settings by long-pressing the widget and selecting "Configure".</string>

    <string name="tour_battery_title">Battery-Aware Updates</string>
    <string name="tour_battery_desc">Update frequency scales based on battery level:\n\n• Plugged in: Every 30 minutes\n• Battery &gt;50%%: Every 1 hour\n• Battery 20–50%%: Every 2 hours\n• Battery &lt;20%%: Every 4 hours\n\nManual refresh is always available by tapping the widget.</string>

    <string name="tour_location_title">Location Options</string>
    <string name="tour_location_desc">Choose your location method when configuring the widget:\n\n• GPS: Automatic location detection\n• ZIP Code: Manual entry for specific location\n• Default: Falls back to Google HQ (37.4220, -122.0841) if location unavailable\n\nThe widget displays the location name at the bottom.</string>

