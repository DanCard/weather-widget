<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/bg_surface_card"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/station_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Station Name"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <TextView
                android:id="@+id/station_id_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KNUQ"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/station_type_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:text="OFFICIAL"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_button_gray" />
        </LinearLayout>

        <TextView
            android:id="@+id/observation_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Observed: 12:35 PM"
            android:textColor="#888888"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/fetch_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fetched: 12:40 PM"
            android:textColor="#888888"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/temperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="72°"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginEnd="12dp" />

    <TextView
        android:id="@+id/condition"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="Clear"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:gravity="center" />

</LinearLayout>
