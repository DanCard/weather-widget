<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@drawable/widget_background">

    <!-- Left navigation arrow - vertically centered, narrow to maximize content area -->
    <ImageButton
        android:id="@+id/nav_left"
        android:layout_width="20dp"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:layout_gravity="start|center_vertical"
        android:src="@drawable/ic_chevron_left"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:contentDescription="@string/nav_previous"
        android:visibility="visible" />

    <!-- Right navigation arrow - vertically centered, narrow to maximize content area -->
    <ImageButton
        android:id="@+id/nav_right"
        android:layout_width="20dp"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:layout_gravity="end|center_vertical"
        android:src="@drawable/ic_chevron_right"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:contentDescription="@string/nav_next"
        android:visibility="visible" />

    <!-- Text-only view (for 1-row height) -->
    <LinearLayout
        android:id="@+id/text_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Day 1 (Yesterday) -->
        <LinearLayout
            android:id="@+id/day1_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/day1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mon"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day1_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day1_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />
        </LinearLayout>

        <!-- Day 2 (Today) - Always visible -->
        <LinearLayout
            android:id="@+id/day2_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/day2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day2_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day2_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />
        </LinearLayout>

        <!-- Day 3 (Tomorrow) -->
        <LinearLayout
            android:id="@+id/day3_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/day3_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wed"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day3_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day3_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />
        </LinearLayout>

        <!-- Day 4 -->
        <LinearLayout
            android:id="@+id/day4_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/day4_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day4_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day4_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />
        </LinearLayout>

        <!-- Day 5 -->
        <LinearLayout
            android:id="@+id/day5_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/day5_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day5_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day5_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />
        </LinearLayout>

        <!-- Day 6 -->
        <LinearLayout
            android:id="@+id/day6_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/day6_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day6_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day6_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />
        </LinearLayout>

    </LinearLayout>

    <!-- Graph view (for 2+ row height) -->
    <ImageView
        android:id="@+id/graph_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:scaleType="fitXY"
        android:visibility="gone" />

    <!-- Current temperature indicator - positioned in top-left corner -->
    <TextView
        android:id="@+id/current_temp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="-4dp"
        android:text="72°"
        android:textSize="30sp"
        android:textColor="#AAFFFFFF"
        android:visibility="visible" />

    <!-- API Source indicator - rendered last for touch priority, positioned in top-right corner -->
    <FrameLayout
        android:id="@+id/api_source_container"
        android:layout_width="64dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-4dp"
        android:layout_marginEnd="-4dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/api_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="4dp"
            android:text="NWS"
            android:textSize="11sp"
            android:textColor="#AAFFFFFF"
            android:visibility="visible" />

    </FrameLayout>

</FrameLayout>
