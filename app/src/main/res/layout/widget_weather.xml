<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@drawable/widget_background">

    <!-- Left navigation arrow - vertically centered, narrow to maximize content area -->
    <ImageButton
        android:id="@+id/nav_left"
        android:layout_width="20dp"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:layout_gravity="start|center_vertical"
        android:src="@drawable/ic_chevron_left"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:contentDescription="@string/nav_previous"
        android:visibility="visible" />

    <!-- Right navigation arrow - vertically centered, narrow to maximize content area -->
    <ImageButton
        android:id="@+id/nav_right"
        android:layout_width="20dp"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:layout_gravity="end|center_vertical"
        android:src="@drawable/ic_chevron_right"
        android:background="@android:color/transparent"
        android:scaleType="centerInside"
        android:contentDescription="@string/nav_next"
        android:visibility="visible" />

    <!-- Text-only view (for 1-row height) -->
    <LinearLayout
        android:id="@+id/text_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Day 1 (Yesterday) -->
        <LinearLayout
            android:id="@+id/day1_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/day1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mon"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <ImageView
                android:id="@+id/day1_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:src="@drawable/ic_weather_unknown"
                android:visibility="gone"
                android:tint="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day1_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day1_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day1_rain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textSize="11sp"
                android:textColor="#5AC8FA"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Day 2 (Today) - Always visible -->
        <LinearLayout
            android:id="@+id/day2_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/day2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <ImageView
                android:id="@+id/day2_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:src="@drawable/ic_weather_unknown"
                android:visibility="gone"
                android:tint="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day2_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day2_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day2_rain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textSize="11sp"
                android:textColor="#5AC8FA"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Day 3 (Tomorrow) -->
        <LinearLayout
            android:id="@+id/day3_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/day3_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wed"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <ImageView
                android:id="@+id/day3_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:src="@drawable/ic_weather_unknown"
                android:visibility="gone"
                android:tint="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day3_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day3_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day3_rain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textSize="11sp"
                android:textColor="#5AC8FA"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Day 4 -->
        <LinearLayout
            android:id="@+id/day4_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/day4_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <ImageView
                android:id="@+id/day4_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:src="@drawable/ic_weather_unknown"
                android:visibility="gone"
                android:tint="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day4_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day4_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day4_rain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textSize="11sp"
                android:textColor="#5AC8FA"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Day 5 -->
        <LinearLayout
            android:id="@+id/day5_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/day5_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <ImageView
                android:id="@+id/day5_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:src="@drawable/ic_weather_unknown"
                android:visibility="gone"
                android:tint="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day5_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day5_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day5_rain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textSize="11sp"
                android:textColor="#5AC8FA"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Day 6 -->
        <LinearLayout
            android:id="@+id/day6_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/day6_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <ImageView
                android:id="@+id/day6_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:src="@drawable/ic_weather_unknown"
                android:visibility="gone"
                android:tint="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day6_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day6_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day6_rain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textSize="11sp"
                android:textColor="#5AC8FA"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Day 7 -->
        <LinearLayout
            android:id="@+id/day7_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/day7_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <ImageView
                android:id="@+id/day7_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:src="@drawable/ic_weather_unknown"
                android:visibility="gone"
                android:tint="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day7_high"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="22sp"
                android:textColor="@color/widget_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/day7_low"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--°"
                android:textSize="18sp"
                android:textColor="@color/widget_text_secondary" />

            <TextView
                android:id="@+id/day7_rain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text=""
                android:textSize="11sp"
                android:textColor="#5AC8FA"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

    <!-- Graph view (for 2+ row height) -->
    <ImageView
        android:id="@+id/graph_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:scaleType="fitCenter"
        android:visibility="gone" />

    <!-- Graph day touch zones (for per-day click handling in graph mode) -->
    <LinearLayout
        android:id="@+id/graph_day_zones"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/graph_day1_zone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/graph_day2_zone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/graph_day3_zone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/graph_day4_zone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/graph_day5_zone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/graph_day6_zone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/graph_day7_zone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Left navigation touch zone - invisible overlay for larger touch target -->
    <FrameLayout
        android:id="@+id/nav_left_zone"
        android:layout_width="32dp"
        android:layout_height="match_parent"
        android:layout_gravity="start|center_vertical"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true" />

    <!-- Right navigation touch zone - invisible overlay for larger touch target -->
    <FrameLayout
        android:id="@+id/nav_right_zone"
        android:layout_width="32dp"
        android:layout_height="match_parent"
        android:layout_gravity="end|center_vertical"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true" />

    <!-- Current temperature touch zone - invisible overlay for larger touch target -->
    <FrameLayout
        android:id="@+id/current_temp_zone"
        android:layout_width="80dp"
        android:layout_height="56dp"
        android:layout_gravity="top|start"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true" />

    <!-- Precipitation probability touch zone - invisible overlay for larger touch target -->
    <FrameLayout
        android:id="@+id/precip_touch_zone"
        android:layout_width="72dp"
        android:layout_height="40dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="72dp"
        android:layout_marginTop="4dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true" />

    <!-- Current temperature and weather icon - positioned in top-left corner -->
    <LinearLayout
        android:id="@+id/current_weather_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginTop="-4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/weather_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_weather_unknown"
            android:contentDescription="@string/weather_icon_desc"
            android:visibility="gone"
            android:layout_marginEnd="2dp"
            android:tint="#AAFFFFFF" />

        <TextView
            android:id="@+id/current_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="72°"
            android:textSize="26sp"
            android:textColor="#AAFFFFFF"
            android:visibility="visible" />

        <TextView
            android:id="@+id/precip_probability"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:paddingEnd="48dp"
            android:text=""
            android:textSize="26sp"
            android:textColor="#AA5AC8FA"
            android:visibility="gone" />

    </LinearLayout>

    <!-- API Source indicator - rendered last for touch priority, positioned in top-right corner -->
    <FrameLayout
        android:id="@+id/api_source_container"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-4dp"
        android:layout_marginEnd="10dp"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true"
        android:paddingStart="8dp"
        android:paddingEnd="6dp">

        <TextView
            android:id="@+id/api_source"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="4dp"
            android:text="NWS"
            android:textSize="11sp"
            android:textColor="#AAFFFFFF"
            android:visibility="visible" />

    </FrameLayout>

</FrameLayout>
